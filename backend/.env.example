# FastAPI Configuration
PORT=8000
DEBUG=True

# Database Configuration (Supabase PostgreSQL connection string)
# Example: postgresql://postgres:password@db.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres.your-project-id:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require

# JWT Authentication
# Generate a secure secret key: openssl rand -hex 32
JWT_SECRET=super_secret_jwt_key_change_me_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Supabase Storage Configuration (For Receipt Uploads)
# Create a public bucket in Supabase Storage named "receipts"
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key
SUPABASE_BUCKET=receipts
